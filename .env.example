# API Configuration
VITE_API_URL=http://localhost:5000/api
VITE_WS_URL=ws://localhost:5000

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Map Configuration
VITE_MAPBOX_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
VITE_OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Analytics
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxx

# Feature Flags
VITE_ENABLE_CHAT=true
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_NOTIFICATIONS=true

# App Configuration
